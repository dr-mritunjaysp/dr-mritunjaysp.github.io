@article{peelam2024quantum,
  title        = {Quantum computing applications for Internet of Things},
  author       = {Mritunjay Shall Peelam and Rout, Anjaney Asreet and Chamola, Vinay},
  journal      = {IET Quantum Communication},
  volume       = {5},
  number       = {2},
  pages        = {103--112},
  year         = {2024},

  abbr         = {IET QC},
  bibtex_show  = {true},

  doi          = {10.1049/qtc2.12079},
  html         = {https://ietresearch.onlinelibrary.wiley.com/doi/10.1049/qtc2.12079},
  pdf          = {https://ietresearch.onlinelibrary.wiley.com/doi/pdfdirect/10.1049/qtc2.12079?download=true},

  preview      = {p1.gif},

  dimensions   = {true},
  altmetric    = {true},

  abstract     = {The rapidly developing discipline of quantum computing (QC) employs ideas from quantum physics to improve the performance of traditional computers and other devices. Because of the dramatically improved speed at which it processes data, it can be applied to various issues. QC has many potential applications, but three of the most exciting applications are unstructured search, quantum simulation, and network optimisation. Several existing technologies, such as machine learning, may benefit from its increased speed and precision. In this study, the authors explore how the principles of QC might be applied to the Internet of Things (IoT) to improve its accuracy, speed, and security. Several approaches exist for achieving this goal, such as network optimisation in IoT using QC, faster computation at IoT endpoints, securing IoT using QC, quantum sensors for IoT, quantum digital marketing, and quantum-secured smart locks.},

  additional_info = {Q2 Journal | Scopus Indexed | Impact Factor: 2.8},

  selected     = {true}
}


@article{peelam2024qiotchain,
  title        = {QIoTChain: Quantum IoT-blockchain fusion for advanced data protection in Industry 4.0},
  author       = {Sharma, Aditya Kumar and {Mritunjay Shall Peelam} and Chaurasia, Brijesh Kumar and Chamola, Vinay},
  journal      = {IET Blockchain},
  volume       = {4},
  number       = {3},
  pages        = {252--262},
  year         = {2024},

  abbr         = {IET BLC},
  bibtex_show  = {true},

  doi          = {https://doi.org/10.1049/blc2.12059},
  html         = {https://ietresearch.onlinelibrary.wiley.com/doi/full/10.1049/blc2.12059},
  pdf          = {https://ietresearch.onlinelibrary.wiley.com/doi/epdf/10.1049/blc2.12059},

  preview      = {p2.gif},

  dimensions   = {true},
  altmetric    = {true},

  abstract     = {The modern world is driven by data, making its protection critical in Industry 4.0 environments. This paper analyses a Quantum-IoT-based data protection scheme integrating quantum computing, blockchain, and IoT. It highlights how post-quantum cryptographic mechanisms and distributed systems can enhance security, improve trust, and address limitations of existing architectures. The study also explores future-ready innovations enabled by quantum technologies for secure and efficient data-driven systems.},

  additional_info = {Q2 Journal | Scopus Indexed},

  selected     = {true}
}

---
layout: default
---
<div class="post">
  <header class="post-header about-header">
    {% if page.profile and page.profile.image %}
      {% assign profile_image_path = page.profile.image | prepend: 'assets/img/' %}
      <div class="about-header-photo-ring">
        <div class="about-header-photo-shell">
          <img
            src="{{ profile_image_path | relative_url | bust_file_cache }}"
            class="about-header-photo{% if page.profile.image_circular %} rounded-circle{% else %} rounded{% endif %}"
            alt="{{ page.profile.image }}"
            loading="eager"
          >
        </div>
      </div>
    {% endif %}

    <div class="about-header-text">
      <h1 class="post-title">
        {% if site.title == 'blank' %}
          <span class="font-weight-bold">{{ site.first_name }} {{ site.middle_name }} {{ site.last_name }}</span>
        {% else %}
          {{ site.title }}
        {% endif %}
      </h1>

      <p class="desc">{{ page.subtitle }}</p>
    </div>
  </header>

  <article>
    <div class="about-layout">
      <div class="about-content clearfix">{{ content }}</div>
    </div>

    <!-- News -->
    {% if page.announcements and page.announcements.enabled %}
      <h2>
        <a href="{{ '/news/' | relative_url }}" style="color: inherit">news</a>
      </h2>
      {% include news.liquid limit=true %}
    {% endif %}

    <!-- Latest posts -->
    {% if page.latest_posts and page.latest_posts.enabled %}
      <h2>
        <a href="{{ '/blog/' | relative_url }}" style="color: inherit">latest posts</a>
      </h2>
      {% include latest_posts.liquid %}
    {% endif %}

    <!-- Selected papers -->
    {% if page.selected_papers %}
      <h2>
        <a href="{{ '/publications/' | relative_url }}" style="color: inherit">selected publications</a>
      </h2>
      {% include selected_papers.liquid %}
    {% endif %}

    <!-- Social -->
    {% if page.social %}
      <div class="social">
        <div class="contact-icons">{% social_links %}</div>
        {% include visitor-counter.liquid %}

        <div class="contact-note">{{ site.contact_note }}</div>
      </div>
    {% endif %}

    {% if site.newsletter and site.newsletter.enabled and site.footer_fixed %}
      {% include newsletter.liquid center=true %}
    {% endif %}
  </article>
</div>

<!doctype html>
<html lang="{{ site.lang }}">
  <!-- Head -->
  <head>
    {% if page.redirect %}
      {% if page.redirect == true %}
        {% assign redirect = site.baseurl | append: '/' %}
      {% elsif page.redirect contains '://' %}
        {% assign redirect = page.redirect %}
      {% else %}
        {% assign redirect = page.redirect | relative_url %}
      {% endif %}
      <meta http-equiv="refresh" content="3; url={{ redirect }}">
    {% endif %}
    {% include head.liquid %}
  </head>

  <!-- Body -->
  <body class="{% if site.navbar_fixed %}fixed-top-nav{% endif %} {% unless site.footer_fixed %}sticky-bottom-footer{% endunless %}">
    <!-- Header -->
    {% include header.liquid %}

    <!-- Content -->
    <div class="container site-main-container" role="main">
      {% if page.toc and page.toc.sidebar %}
        {% if page.toc.sidebar == 'right' %}
          <div class="row">
            <!-- main content area -->
            <div class="col-sm-9">{{ content }}</div>
            <!-- sidebar, which will move to the top on a small screen -->
            <div class="col-sm-3">
              <nav id="toc-sidebar" class="sticky-top"></nav>
            </div>
          </div>
        {% else %}
          <div class="row">
            <!-- sidebar, which will move to the top on a small screen -->
            <div class="col-sm-3">
              <nav id="toc-sidebar" class="sticky-top"></nav>
            </div>
            <!-- main content area -->
            <div class="col-sm-9">{{ content }}</div>
          </div>
        {% endif %}
      {% else %}
        {{ content }}
      {% endif %}
    </div>

    <!-- Footer -->
    {% include footer.liquid %}

    <script type="module">
      import { initializeApp } from 'https://www.gstatic.com/firebasejs/12.0.0/firebase-app.js';
      import {
        getDatabase,
        get,
        ref,
        runTransaction,
      } from 'https://www.gstatic.com/firebasejs/12.0.0/firebase-database.js';

      document.addEventListener('DOMContentLoaded', async function () {
        const valueNode = document.getElementById('visitor-counter-value');
        if (!valueNode) return;

        const firebaseConfig = {
          apiKey: {{ site.visitor_counter.firebase.api_key | jsonify }},
          authDomain: {{ site.visitor_counter.firebase.auth_domain | jsonify }},
          databaseURL: {{ site.visitor_counter.firebase.database_url | jsonify }},
          projectId: {{ site.visitor_counter.firebase.project_id | jsonify }},
          appId: {{ site.visitor_counter.firebase.app_id | jsonify }},
        };

        const isConfigured = Object.values(firebaseConfig).every(
          (value) => value && !String(value).includes('YOUR_')
        );

        if (!isConfigured) {
          valueNode.textContent = 'Set Firebase';
          return;
        }

        const animateValue = (count) => {
          const duration = 700;
          const startTime = performance.now();

          valueNode.classList.add('is-animating');

          const step = (currentTime) => {
            const progress = Math.min((currentTime - startTime) / duration, 1);
            const eased = 1 - Math.pow(1 - progress, 3);
            const currentValue = Math.round(count * eased);

            valueNode.textContent = currentValue.toLocaleString();

            if (progress < 1) {
              window.requestAnimationFrame(step);
            } else {
              valueNode.textContent = count.toLocaleString();
              valueNode.classList.remove('is-animating');
            }
          };

          window.requestAnimationFrame(step);
        };

        const pageKey = {{ page.url | replace: '.', '-' | replace: '#', '-' | replace: '$', '-' | replace: '[', '-' | replace: ']', '-' | jsonify }};

        try {
          const app = initializeApp(firebaseConfig);
          const database = getDatabase(app);
          const counterRef = ref(database, `visitor-counter/${pageKey}`);

          await runTransaction(counterRef, (currentValue) => (currentValue || 0) + 1);
          const snapshot = await get(counterRef);
          animateValue(snapshot.exists() ? snapshot.val() : 0);
        } catch (error) {
          valueNode.textContent = '0';
        }
      });
    </script>

    <!-- JavaScripts -->
    {% include scripts.liquid %}
  </body>
</html>
